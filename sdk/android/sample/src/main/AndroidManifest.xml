<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="ai.vanaras.a2g.sample">

    <!-- AAOS compatibility: requires Android Automotive OS feature -->
    <uses-feature android:name="android.hardware.type.automotive" android:required="true" />

    <!-- Car permissions required by CarPropertyManager -->
    <uses-permission android:name="android.car.permission.CAR_HVAC" />
    <uses-permission android:name="android.car.permission.CONTROL_CAR_WINDOWS" />
    <uses-permission android:name="android.car.permission.CONTROL_CAR_DOORS" />

    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <activity
            android:name=".DemoActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!--
                    AAOS app entry point.
                    On a real AAOS head unit, this activity appears in the app drawer.
                -->
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>

</manifest>
